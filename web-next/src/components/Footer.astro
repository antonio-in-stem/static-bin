---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";

const year = new Date().getFullYear();

const stats = [
  { label: "Version",   value: "1.0.0"    },
  { label: "Released",  value: "Jan 2026" },
  { label: "License",   value: "MIT"      },
  { label: "Ports",     value: "4"        },
];
---

<footer class="footer">
  <div class="container-xl">
    <div class="footer-stats">
      {stats.map((s) => (
        <div class="footer-stat surface card-hover glow-track">
          <div class="footer-stat-label">{s.label}</div>
          <div class="footer-stat-value">{s.value}</div>
        </div>
      ))}
    </div>

    <div class="footer-bottom">
      <div class="footer-brand">
        <Image src={logo} alt="" width={22} height={22} format="webp" quality={92} />
        <span>
          StaticBin, a
          <a
            href="https://www.linkedin.com/in/antonio-in-stem/"
            target="_blank"
            rel="noopener noreferrer"
          >Antonio M.</a>
          artifact via StaticResearch.
        </span>
      </div>

      <div class="footer-social">
        <a
          href="https://github.com/antonio-in-stem/static-bin"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5a11.5 11.5 0 00-3.63 22.4c.58.1.79-.25.79-.55v-2.02c-3.2.7-3.88-1.37-3.88-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.02 1.76 2.69 1.25 3.35.96.1-.75.4-1.25.73-1.54-2.56-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18.92-.26 1.9-.39 2.88-.39.98 0 1.96.13 2.88.39 2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.4-5.25 5.69.41.36.78 1.06.78 2.14v3.17c0 .3.21.66.8.55A11.5 11.5 0 0012 .5z"/></svg>
        </a>
        <a
          href="https://www.linkedin.com/in/antonio-in-stem/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.56c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.66H9.35V9h3.4v1.56h.05c.48-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 110-4.11 2.06 2.06 0 010 4.11zM3.56 20.45h3.55V9H3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.22 0z"/></svg>
        </a>
      </div>

      <div class="footer-copy">Â© {year} Â· Antonio M. Â· StaticResearch</div>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: clamp(6rem, 12vh, 10rem);
    padding: clamp(4rem, 8vh, 6rem) 0 3rem;
    position: relative;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .footer-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }
  @media (max-width: 640px) {
    .footer-stats { grid-template-columns: repeat(2, 1fr); }
  }
  .footer-stat {
    padding: 1.25rem 1.5rem;
  }
  .footer-stat-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-ink-400);
    margin-bottom: 0.4rem;
    letter-spacing: -0.005em;
  }
  .footer-stat-value {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 2rem;
    letter-spacing: -0.02em;
    color: var(--color-ink-50);
    line-height: 1;
  }

  .footer-bottom {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--color-ink-300);
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    letter-spacing: -0.005em;
  }
  .footer-brand a {
    color: var(--color-signal-500);
    transition: color 200ms;
  }
  .footer-brand a:hover { color: var(--color-signal-300); }

  .footer-social {
    display: flex;
    gap: 0.4rem;
  }
  .footer-social a {
    display: inline-flex;
    width: 32px;
    height: 32px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: var(--color-ink-400);
    transition: all 200ms;
  }
  .footer-social a:hover {
    color: var(--color-ink-50);
    background: rgba(255,255,255,0.05);
  }

  .footer-copy {
    font-size: 12px;
    color: var(--color-ink-400);
    letter-spacing: -0.005em;
  }
</style>
