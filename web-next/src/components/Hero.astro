---
const sampleToken = "OmqAqDZIQCAKA";
const chars = [...sampleToken];
---

<section class="hero" id="hero" data-hero>
  <div class="hero-mesh" data-hero-mesh aria-hidden="true"></div>
  <div class="hero-grain" aria-hidden="true"></div>

  <div class="container-xl hero-stack">
    <div class="hero-top reveal">
      <span class="eyebrow hero-eyebrow">
        <span class="hero-eyebrow-sig">v1.0</span>
        <span class="hero-eyebrow-dot" aria-hidden="true"></span>
        <span>January 2026</span>
        <span class="hero-eyebrow-dot" aria-hidden="true"></span>
        <span>StaticResearch</span>
      </span>
    </div>

    <h1 class="hero-title" data-hero-title>
      <span class="hero-title-line">
        <span data-word>Skip</span>
        <span data-word>the</span>
        <span data-word>schema.</span>
      </span>
      <span class="hero-title-line hero-title-em"><em>
        <span data-word>Ship</span>
        <span data-word>the</span>
        <span data-word>state.</span>
      </em></span>
    </h1>

    <p class="hero-lead reveal" data-reveal-delay="220">
      Both ends of the wire already know the shape of your data. So StaticBin
      doesn't bother sending it. Just the values, packed tight, wrapped in a
      short text token you can drop into a URL. That's the whole idea.
    </p>

    <div class="hero-cta reveal" data-reveal-delay="340">
      <a
        class="btn btn-primary"
        href="#playground"
        data-magnetic="14"
      >
        Try the playground
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="M13 5l7 7-7 7"/>
        </svg>
      </a>
      <a class="btn btn-link" href="#format" data-magnetic="6">
        See the format
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <div class="container-xl hero-visual-wrap reveal" data-reveal-delay="460">
    <div class="hero-token-stage liquid-glass">
      <div class="hero-token" data-hero-token aria-label="Example StaticBin token">
        {chars.map((c, i) => (
          <span class="hero-ch" data-ch data-i={i}>{c}</span>
        ))}
      </div>

      <div class="hero-token-meta">
        <span><strong>144</strong> bits</span>
        <span aria-hidden="true" class="hero-token-sep"></span>
        <span><strong>24</strong> characters</span>
        <span aria-hidden="true" class="hero-token-sep"></span>
        <span>base64url</span>
      </div>
    </div>
  </div>

  <a href="#rationale" class="hero-scroll-hint" aria-label="Scroll to rationale">
    <span>scroll</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14"/><path d="M5 12l7 7 7-7"/></svg>
  </a>
</section>

<script>
  import "../lib/hero-scroll";
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    padding-top: clamp(6rem, 14vh, 9rem);
    padding-bottom: clamp(3rem, 6vh, 5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-mesh {
    position: absolute;
    inset: -20%;
    pointer-events: none;
    z-index: -1;
    background:
      radial-gradient(closest-side at 30% 40%, rgba(41,151,255,0.22), transparent 55%),
      radial-gradient(closest-side at 70% 65%, rgba(198,168,119,0.14), transparent 55%),
      radial-gradient(closest-side at 50% 90%, rgba(41,151,255,0.1), transparent 60%);
    filter: blur(40px) saturate(1.1);
    will-change: transform, opacity;
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    opacity: 0.45;
    mix-blend-mode: overlay;
    background-image:
      radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 3px 3px;
    mask-image: linear-gradient(180deg, transparent, rgba(0,0,0,0.7) 40%, rgba(0,0,0,0.9));
  }

  .hero-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* eyebrow · now without the pulsing dot */
  .hero-eyebrow {
    padding: 0.45rem 1rem;
    background: rgba(255,255,255,0.035);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 999px;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--color-ink-100);
    letter-spacing: -0.005em;
    backdrop-filter: blur(16px) saturate(1.3);
    -webkit-backdrop-filter: blur(16px) saturate(1.3);
  }
  .hero-eyebrow-sig {
    color: var(--color-signal-300);
    font-variant-numeric: tabular-nums;
  }
  .hero-eyebrow-dot {
    width: 3px;
    height: 3px;
    border-radius: 999px;
    background: var(--color-ink-500);
    display: inline-block;
  }

  .hero-title {
    margin-top: 1.75rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.85rem, 8.2vw, 6.8rem);
    line-height: 1.02;
    letter-spacing: -0.045em;
    color: var(--color-ink-50);
    max-width: 15ch;
  }

  .hero-title-line { display: block; }

  /* The italic display line. Solid color, no gradient clip. Instrument
     Serif italic is editorial on its own. Soft text-shadow for luminance. */
  .hero-title-em em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 1.02em;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-ink-50);
    text-shadow:
      0 0 80px rgba(41, 151, 255, 0.22),
      0 2px 30px rgba(0, 0, 0, 0.5);
  }

  .hero-title [data-word] {
    display: inline-block;
    will-change: transform, opacity, filter;
    margin-inline-end: 0.16em;
  }
  .hero-title-em [data-word] {
    /* elegant italic moments are slightly tighter */
    margin-inline-end: 0.08em;
  }

  .hero-lead {
    margin-top: 1.75rem;
    max-width: 52ch;
    font-size: clamp(1.0625rem, 1.35vw, 1.225rem);
    color: var(--color-ink-200);
    line-height: 1.5;
    letter-spacing: -0.01em;
  }

  .hero-cta {
    margin-top: 2.25rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── hero visual ─────────────────────────────────────── */
  .hero-visual-wrap {
    margin-top: clamp(3.5rem, 7vh, 6rem);
    display: flex;
    justify-content: center;
  }

  .hero-token-stage {
    padding: clamp(2.5rem, 5vw, 4rem) clamp(2rem, 6vw, 5rem) clamp(2.5rem, 4vw, 3.25rem);
    border-radius: var(--radius-xl);
    width: min(880px, 100%);
    text-align: center;
    transform-style: preserve-3d;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.08),
      0 40px 100px -30px rgba(0,0,0,0.8),
      0 0 140px -20px rgba(41,151,255,0.28);
  }

  .hero-token {
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    display: inline-flex;
    gap: clamp(0.2rem, 0.4vw, 0.4rem);
    font-family: var(--font-mono);
    font-size: clamp(2.4rem, 6vw, 4.75rem);
    font-weight: 500;
    letter-spacing: 0;
    color: var(--color-ink-50);
    transform: perspective(1200px) rotateX(var(--tilt-x)) rotateY(var(--tilt-y));
    transform-style: preserve-3d;
    transition: transform 800ms var(--ease-out-quint);
    will-change: transform;
  }

  .hero-ch {
    display: inline-block;
    will-change: transform, opacity;
    background: linear-gradient(180deg, #f5f5f7 0%, #a1a1a6 110%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    text-shadow: 0 0 40px rgba(41,151,255,0.25);
  }

  .hero-token-meta {
    margin-top: clamp(1.5rem, 2.5vw, 2.25rem);
    padding-top: clamp(1.25rem, 2vw, 1.75rem);
    border-top: 1px solid rgba(255,255,255,0.06);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(0.8rem, 2vw, 1.5rem);
    font-size: 13px;
    color: var(--color-ink-300);
    font-weight: 400;
    letter-spacing: -0.005em;
    flex-wrap: wrap;
  }
  .hero-token-meta strong {
    color: var(--color-ink-50);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }
  .hero-token-sep {
    width: 3px;
    height: 3px;
    border-radius: 999px;
    background: var(--color-ink-500);
  }

  /* ── scroll hint ─────────────────────────────────────── */
  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-ink-400);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.9;
    transition: color 250ms;
  }
  .hero-scroll-hint:hover { color: var(--color-ink-100); }
  .hero-scroll-hint svg { animation: hint-bob 2.4s var(--ease-in-out-quart) infinite; }
  @keyframes hint-bob {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50%      { transform: translateY(4px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scroll-hint svg { animation: none; }
  }

  @media (max-width: 640px) {
    .hero-token {
      font-size: clamp(1.6rem, 7.5vw, 2.5rem);
      gap: 0.1rem;
    }
    .hero-eyebrow { font-size: 11.5px; padding: 0.4rem 0.85rem; }
    .hero-eyebrow-sig + .hero-eyebrow-dot + span + .hero-eyebrow-dot + span { display: none; }
  }
</style>
