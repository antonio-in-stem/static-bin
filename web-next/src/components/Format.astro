---
import SectionTitle from "./SectionTitle.astro";

const modes = [
  {
    tag: "01",
    name: "Fixed",
    copy: "Every chunk is the same width. Ideal for booleans, enums, fixed-size integers, and fixed-width text.",
    example: "encode_fixed(['01100001', '01100010', '01100011'])",
    example_label: "3 bytes of ASCII, 26 bits on the wire",
  },
  {
    tag: "10",
    name: "Dynamic",
    copy: "Each chunk declares its own length with Elias-gamma. Good for variable-width payloads with a long tail.",
    example: "encode_dynamic(['1', '1010', '110011', '10'])",
    example_label: "4 tokens of mixed width, self-delimited",
  },
  {
    tag: "11",
    name: "Integer",
    copy: "Raw Elias-gamma integers, no wrapping. Perfect for small positive counters, indices, and ids.",
    example: "encode_integers([1, 2, 3, 5, 8, 13, 21])",
    example_label: "Fibonacci preamble, 22 bits total",
  },
];
---

<section class="sect" id="format">
  <div class="container-xl">
    <SectionTitle
      eyebrow="three primitives. one stream."
      eyebrowEm="Format."
      title={`Small enough to <em>memorise.</em>`}
      description="The wire format is a two-bit section tag followed by an Elias-gamma length and the payload. Three tags cover every shape of shared-schema data we've actually needed."
    />

    <div class="schema liquid-glass reveal">
      <div class="schema-head">
        <span class="eyebrow eyebrow-warm">Anatomy of a stream</span>
      </div>
      <div class="schema-bits">
        <div class="bg g-outer">
          <code>010…01</code>
          <span>outer length (Elias-γ)</span>
        </div>
        <div class="bg g-tag">
          <code>01</code>
          <span>section tag</span>
        </div>
        <div class="bg g-len">
          <code>0..1…</code>
          <span>section length</span>
        </div>
        <div class="bg g-payload">
          <code>payload bits</code>
          <span>chunks</span>
        </div>
        <div class="bg g-tag">
          <code>10</code>
          <span>section tag</span>
        </div>
        <div class="bg g-payload">
          <code>…</code>
          <span>more chunks</span>
        </div>
      </div>
    </div>

    <div class="modes">
      {modes.map((m) => (
        <article class="mode surface card-hover glow-track reveal">
          <header class="mode-head">
            <span class="mode-tag" aria-hidden="true">{m.tag}</span>
            <h3 class="mode-name">{m.name}</h3>
          </header>
          <p class="mode-copy">{m.copy}</p>
          <pre class="mode-example"><code>{m.example}</code></pre>
          <div class="mode-foot">{m.example_label}</div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .schema {
    padding: 1.75rem 2rem 2rem;
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
  }
  .schema-head { margin-bottom: 1.25rem; }
  .schema-bits {
    display: grid;
    grid-template-columns: 1.2fr 0.4fr 0.55fr 1fr 0.4fr 0.8fr;
    gap: 6px;
  }
  @media (max-width: 820px) {
    .schema-bits { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 480px) {
    .schema-bits { grid-template-columns: repeat(2, 1fr); }
  }

  .bg {
    position: relative;
    padding: 0.8rem 0.9rem;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
    transition: border-color 300ms, background 300ms;
  }
  .bg:hover { border-color: rgba(255,255,255,0.15); }
  .bg code {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-100);
    display: block;
  }
  .bg span {
    display: block;
    margin-top: 0.35rem;
    font-size: 11px;
    color: var(--color-ink-400);
    letter-spacing: -0.005em;
  }
  .g-outer { border-color: rgba(41, 151, 255, 0.22); }
  .g-outer code { color: var(--color-signal-300); }
  .g-tag { border-color: rgba(198, 168, 119, 0.35); }
  .g-tag code { color: var(--color-warmth-300); font-weight: 600; }
  .g-payload { background: rgba(41, 151, 255, 0.04); }

  .modes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  @media (max-width: 980px) {
    .modes { grid-template-columns: 1fr; }
  }

  .mode {
    padding: clamp(1.5rem, 2vw, 1.9rem);
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    min-height: 320px;
  }

  .mode-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .mode-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 0.25rem 0.55rem;
    border-radius: 6px;
    background: rgba(41, 151, 255, 0.1);
    color: var(--color-signal-300);
    border: 1px solid rgba(41, 151, 255, 0.25);
    letter-spacing: 0.05em;
  }
  .mode-name {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.02em;
  }
  .mode-copy {
    font-size: 0.95rem;
    color: var(--color-ink-300);
    line-height: 1.5;
    margin: 0;
  }
  .mode-example {
    background: var(--color-ink-900);
    padding: 0.85rem 1rem;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    overflow-x: auto;
    font-size: 12.5px;
    color: var(--color-ink-100);
    margin: 0;
    margin-top: auto;
  }
  .mode-example code {
    color: inherit;
    font-family: var(--font-mono);
  }
  .mode-foot {
    font-size: 11px;
    color: var(--color-ink-400);
    letter-spacing: -0.005em;
  }
</style>
